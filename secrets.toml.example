# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: NO subas este archivo a GitHub (.gitignore ya lo protege).
# En Streamlit Cloud, pega el contenido en: Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

[github]
token  = "ghp_TU_TOKEN_AQUI"          # Personal Access Token con permisos repo→Contents
repo   = "tu-usuario/finance-tracker-data"  # Repo donde se guardan los datos (puede ser privado)
branch = "main"                        # Rama del repo de datos
